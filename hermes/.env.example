# Backend (Django) job API
BACKEND_URL=http://localhost:8000
HERMES_API_TOKEN=dev-hermes-token
POLL_INTERVAL=3

# AI provider — OpenAI-compatible (default: SumoPod)
AI_BASE_URL=https://ai.sumopod.com/v1
AI_API_KEY=
AI_TEXT_MODEL=gpt-4o-mini
# Set to "dall-e-3" (or provider equivalent) to enable featured image generation.
# Leave empty to skip image generation.
AI_IMAGE_MODEL=
