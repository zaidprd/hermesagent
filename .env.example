# ── Django ─────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=*

# ── Database ───────────────────────────────────────────
# Lokal tanpa Docker: kosongkan DATABASE_URL -> pakai SQLite.
# Dengan Docker: di-set otomatis oleh docker-compose ke PostgreSQL.
POSTGRES_DB=seozaidly
POSTGRES_USER=seozaidly
POSTGRES_PASSWORD=seozaidly
# DATABASE_URL=postgres://seozaidly:seozaidly@localhost:5432/seozaidly

# ── Google OAuth (opsional) ────────────────────────────
# Kosongkan untuk menonaktifkan login Google (login email tetap jalan).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Hermes worker ──────────────────────────────────────
# Token statis yang dipakai Hermes untuk autentikasi ke job API.
HERMES_API_TOKEN=dev-hermes-token

# ── Billing Mayar.id ───────────────────────────────────
# Webhook secret dari dashboard Mayar.id (untuk verifikasi HMAC-SHA256).
MAYAR_WEBHOOK_SECRET=ganti-dengan-webhook-secret-dari-mayar
# URL halaman pembayaran Pro di Mayar.id.
MAYAR_PRO_PAYMENT_URL=https://mayar.id/pay/xxx-your-payment-link
# Batas artikel gratis per bulan (default 10).
BILLING_FREE_ARTICLE_LIMIT=10
